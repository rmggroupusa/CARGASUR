# Copia este archivo como ".env" y llena tus propios valores.
# NUNCA subas el archivo ".env" real a ningun lugar publico (GitHub, etc.)

# Base de datos Postgres (Render, Railway, Supabase, o tu propio servidor)
DATABASE_URL=postgres://usuario:password@host:5432/nombre_db

# Cualquier cadena larga y aleatoria (para firmar las sesiones de login)
JWT_SECRET=cambia-esto-por-algo-largo-y-dificil-de-adivinar

# Panel de Stripe > Developers > API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Panel de Stripe > Developers > Webhooks > (se llena despues de crear el webhook)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Panel de Stripe > Product catalog > crea 2 productos con precio recurrente mensual
STRIPE_PRICE_SHIPPER_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_CARRIER_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Cuanto se cobra por reservar una carga sin membresia (en dolares)
PER_LOAD_PRICE_USD=12

# La URL de tu pagina web (landing page o app) - Stripe redirige aqui despues de pagar
FRONTEND_URL=https://tu-sitio.netlify.app

# Puerto local (Render/Railway lo asignan solos, puedes dejarlo)
PORT=4000
